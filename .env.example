# Copy this file to `.env.local` and fill in your values.
# Next.js loads `.env.local` automatically (it is gitignored).

# -----------------------------------------------------------------------------
# Go High Level — pick ONE approach:
#
# (A) WORKFLOW WEBHOOK (recommended if your Private Integration has no Contacts scope)
#     In GHL: Automation → Create workflow → Inbound Webhook trigger → copy URL.
#     Add actions: Create/Update Contact, map fields from the webhook payload
#     (name, email, phone, message, source).
# -----------------------------------------------------------------------------
GHL_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# (B) REST API (only if your token includes Contacts + Notes for the location)
# -----------------------------------------------------------------------------
GHL_API_KEY=
GHL_LOCATION_ID=
